from __future__ import annotations

import gc
import hashlib
import multiprocessing
import os
import sys
import time
from datetime import datetime, timezone
from pathlib import Path

# ── hot path imports — loaded inside the worker process ──────────────────────
# (not at module level — this file is imported by the orchestrator too)


def _build_payload_cache(payload_gen, seed: int, n: int) -> list:
    """
    Pre-generate all payloads at worker startup.
    Eliminates Decimal construction from the hot path entirely.

    Memory cost: ~500 bytes × 5,555,556 decisions = ~2.6 GB per worker.
    That exceeds available RAM. So we pre-generate BATCHES of 10,000 payloads
    and cycle through them — same statistical distribution, zero hot-path overhead.
    """
    import random
    rng = random.Random(seed)
    return [payload_gen(rng) for _ in range(10_000)]


def worker_entry(
    domain_name:               str,
    n_decisions:               int,
    worker_id:                 int,
    output_dir:                str,
    seed:                      int,
    solver_timeout_ms:         int,
    max_decisions_per_worker:  int,
    checkpoint_every:          int,
    result_queue:              multiprocessing.Queue,
) -> None:
    """
    Runs in a dedicated OS process.
    Each process: sync Guard, direct Z3, zero IPC per decision.
    """
    # ── process-local imports ─────────────────────────────────────────────────
    sys.path.insert(0, str(Path(__file__).parent))
    import orjson                          # 2-10× faster than stdlib json
    import psutil
    from pramanix import Guard, GuardConfig
    from 100m_domain_policies import DOMAINS

    policy_class, payload_gen = DOMAINS[domain_name]

    # ── pre-build payload cache (10k batch, cycled) ───────────────────────────
    payload_cache = _build_payload_cache(payload_gen, seed, 10_000)
    cache_len = len(payload_cache)

    # ── initialise Guard — sync mode, zero IPC ────────────────────────────────
    def make_guard():
        return Guard(
            policy_class,
            GuardConfig(
                execution_mode   = "sync",     # KEY: no IPC, no subprocess
                solver_timeout_ms = solver_timeout_ms,
                solver_rlimit    = 500_000,
                metrics_enabled  = False,
                otel_enabled     = False,
                log_level        = "WARNING",
            ),
        )

    guard = make_guard()
    decisions_on_guard = 0

    # ── file handles ──────────────────────────────────────────────────────────
    out      = Path(output_dir)
    log_path = out / f"{domain_name}_worker_{worker_id:02d}.jsonl"
    ck_path  = out / f"{domain_name}_worker_{worker_id:02d}_checkpoints.jsonl"

    # ── telemetry ─────────────────────────────────────────────────────────────
    proc         = psutil.Process(os.getpid())
    baseline_rss = proc.memory_info().rss / 1_048_576
    t_start      = time.perf_counter()

    n_allow = n_block = n_timeout = n_error = 0
    latencies: list[float] = []
    chain_hash = hashlib.sha256(
        f"pramanix_audit_{domain_name}_worker_{worker_id}".encode()
    ).hexdigest()

    # 8 MB write buffer — one flush per ~100k lines, not per decision
    BUFSIZE = 8 * 1024 * 1024

    with open(log_path, "wb", buffering=BUFSIZE) as log_fh, \
         open(ck_path,  "wb", buffering=0) as ck_fh:    # checkpoints unbuffered

        for i in range(n_decisions):
            # ── pull from pre-built cache (O(1), no Decimal construction) ─────
            intent, state = payload_cache[i % cache_len]

            # ── Z3 verification — direct call, zero IPC ───────────────────────
            t0 = time.perf_counter()
            decision = guard.verify(intent=intent, state=state)
            ms = (time.perf_counter() - t0) * 1000.0

            latencies.append(ms)

            if   decision.allowed:                            n_allow  += 1
            elif "timeout" in decision.status.value:          n_timeout += 1
            elif decision.violated_invariants:                n_block  += 1
            else:                                             n_error  += 1

            # ── rolling chain hash (lightweight audit trail) ───────────────────
            chain_hash = hashlib.sha256(
                chain_hash.encode() +
                decision.decision_id.encode() +
                b"1" if decision.allowed else b"0"
            ).hexdigest()

            # ── JSONL write — orjson, short keys, pre-encoded newline ──────────
            entry = {
                b"s":  i,
                b"ok": 1 if decision.allowed else 0,
                b"st": decision.status.value,
                b"ms": round(ms, 2),
                b"ch": chain_hash[:24],
            }
            # Only include violated_invariants when non-empty (saves ~20 bytes on ALLOW lines)
            if decision.violated_invariants:
                entry[b"vi"] = list(decision.violated_invariants)

            log_fh.write(orjson.dumps(entry) + b"\n")

            # ── worker recycle — keeps Z3 heap bounded ────────────────────────
            decisions_on_guard += 1
            if decisions_on_guard >= max_decisions_per_worker:
                del guard
                gc.collect(0)           # gen0 only — fast, targeted
                guard = make_guard()
                decisions_on_guard = 0

            # ── checkpoint every N decisions ──────────────────────────────────
            if (i + 1) % checkpoint_every == 0:
                elapsed  = time.perf_counter() - t_start
                rss_now  = proc.memory_info().rss / 1_048_576
                rps      = (i + 1) / elapsed

                lat_s = sorted(latencies)
                p99   = lat_s[int(len(lat_s) * 0.99)]

                ckpt = {
                    "w":      worker_id,
                    "seq":    i + 1,
                    "ch":     chain_hash,
                    "p99":    round(p99, 2),
                    "allow":  n_allow,
                    "block":  n_block,
                    "timeout": n_timeout,
                    "error":  n_error,
                    "rps":    round(rps, 1),
                    "rss":    round(rss_now, 2),
                    "ts":     datetime.now(timezone.utc).isoformat(),
                }
                ck_fh.write(orjson.dumps(ckpt) + b"\n")

        # ── final flush: write remaining buffer ───────────────────────────────
        log_fh.flush()

    # ── cleanup ───────────────────────────────────────────────────────────────
    del guard
    gc.collect(2)

    elapsed   = time.perf_counter() - t_start
    final_rss = proc.memory_info().rss / 1_048_576

    lat_s   = sorted(latencies)
    def pct(p):
        idx = int(len(lat_s) * p / 100)
        return round(lat_s[min(idx, len(lat_s) - 1)], 3)

    result_queue.put({
        "worker_id":    worker_id,
        "n_decisions":  n_decisions,
        "n_allow":      n_allow,
        "n_block":      n_block,
        "n_timeout":    n_timeout,
        "n_error":      n_error,
        "elapsed_s":    round(elapsed, 1),
        "avg_rps":      round(n_decisions / elapsed, 1),
        "baseline_rss": round(baseline_rss, 2),
        "final_rss":    round(final_rss, 2),
        "rss_growth":   round(final_rss - baseline_rss, 2),
        "chain_hash":   chain_hash,
        "p50_ms":       pct(50),
        "p95_ms":       pct(95),
        "p99_ms":       pct(99),
        "p999_ms":      pct(99.9),
        "log_file":     str(log_path),
        "ckpt_file":    str(ck_path),
    })


