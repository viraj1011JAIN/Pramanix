"""
benchmarks/100m_orchestrator_fast.py

Replacement for 100m_audit_orchestrator.py.
Uses multiprocessing.Process instead of asyncio.gather.

ARCHITECTURE CHANGE:
  Old: 1 Python process → 18 asyncio coroutines → 18 Guard subprocesses → 18 Z3 subprocesses
       = 2 IPC crossings per decision = ~30ms overhead = 22.6 RPS/worker

  New: 18 OS processes (each contains sync Guard + Z3 in one place)
       = 0 IPC crossings per decision = ~10ms overhead = ~100-120 RPS/worker

TARGET: 2,000-2,200 aggregate RPS → 100M decisions in 12-14 hours.

Usage:
    python benchmarks/100m_orchestrator_fast.py --domain finance
    python benchmarks/100m_orchestrator_fast.py --domain banking
    python benchmarks/100m_orchestrator_fast.py --domain fintech
    python benchmarks/100m_orchestrator_fast.py --domain healthcare
    python benchmarks/100m_orchestrator_fast.py --domain infra
"""
from __future__ import annotations
import argparse
import gc
import json
import multiprocessing
import os
import sys
import time
from datetime import datetime
from pathlib import Path

import psutil

sys.path.insert(0, str(Path(__file__).parent))
from 100m_domain_policies import DOMAINS
from 100m_worker_fast import worker_entry

# ── constants ─────────────────────────────────────────────────────────────────

DECISIONS_PER_DOMAIN      = 100_000_000
N_WORKERS                 = 18
DECISIONS_PER_WORKER      = DECISIONS_PER_DOMAIN // N_WORKERS  # 5_555_556
SOLVER_TIMEOUT_MS         = 150
MAX_DECISIONS_PER_WORKER  = 10_000    # DO NOT CHANGE — keeps RSS bounded
CHECKPOINT_EVERY          = 100_000
BASE_SEED                 = 42
RESULTS_ROOT              = Path("benchmarks/results")


def preflight(domain_name: str) -> bool:
    print(f"\n{'='*60}")
    print(f"  PRE-FLIGHT: {domain_name.upper()}")
    print(f"{'='*60}")

    checks = {}

    disk = psutil.disk_usage("C:\\")
    free_gb = disk.free / 1024**3
    checks["disk_25gb"] = free_gb >= 25
    print(f"  {'✓' if checks['disk_25gb'] else '✗'} disk free: {free_gb:.1f} GB")

    mem = psutil.virtual_memory()
    free_ram = mem.available / 1024**3
    # 18 processes × ~200 MB each (Z3 heap + payload cache) = ~3.6 GB
    checks["ram_4gb"] = free_ram >= 4
    print(f"  {'✓' if checks['ram_4gb'] else '✗'} RAM free: {free_ram:.1f} GB (need ≥ 4)")

    cpu = psutil.cpu_percent(interval=2)
    checks["cpu_idle"] = cpu < 30
    print(f"  {'✓' if checks['cpu_idle'] else '✗'} CPU idle: {100-cpu:.0f}%")

    # Sleep disabled check
    try:
        import subprocess
        result = subprocess.run(
            ["powercfg", "-query", "SCHEME_CURRENT", "SUB_SLEEP"],
            capture_output=True, text=True
        )
        sleep_disabled = "0x00000000" in result.stdout
        checks["sleep_disabled"] = sleep_disabled
        print(f"  {'✓' if sleep_disabled else '✗'} sleep disabled: {'YES' if sleep_disabled else 'NO — run disable_sleep.ps1 first'}")
    except Exception:
        checks["sleep_disabled"] = True  # can't check, assume OK
        print(f"  ~ sleep check: skipped")

    ok = all(checks.values())
    print(f"\n  {'GO ✓' if ok else 'NO-GO ✗'}")
    print(f"{'='*60}\n")
    return ok


def make_run_dir(domain_name: str) -> Path:
    ts      = datetime.now().strftime("%Y%m%d_%H%M%S")
    run_dir = RESULTS_ROOT / f"run_{domain_name}_{ts}"
    (run_dir / "workers").mkdir(parents=True, exist_ok=True)
    return run_dir


def run_domain(domain_name: str, run_dir: Path) -> dict:
    workers_dir = run_dir / "workers"

    proc         = psutil.Process(os.getpid())
    baseline_rss = proc.memory_info().rss / 1_048_576

    meta = {
        "domain":                   domain_name,
        "architecture":             "multiprocessing.Process + sync Guard (zero IPC per decision)",
        "decisions":                DECISIONS_PER_DOMAIN,
        "n_workers":                N_WORKERS,
        "decisions_per_worker":     DECISIONS_PER_WORKER,
        "max_decisions_per_worker": MAX_DECISIONS_PER_WORKER,
        "solver_timeout_ms":        SOLVER_TIMEOUT_MS,
        "baseline_rss_mib":         round(baseline_rss, 2),
        "started_at":               datetime.now().isoformat(),
        "run_dir":                  str(run_dir),
    }
    with open(run_dir / "run_meta.json", "w") as f:
        json.dump(meta, f, indent=2)

    print(f"\n[{domain_name.upper()}] launching {N_WORKERS} OS processes...")
    print(f"  {DECISIONS_PER_WORKER:,} decisions/worker × {N_WORKERS} workers = {DECISIONS_PER_DOMAIN:,} total")
    print(f"  expected: ~100-120 RPS/worker → ~{N_WORKERS*110:,} aggregate RPS")
    print(f"  expected wall time: ~{DECISIONS_PER_DOMAIN / (N_WORKERS * 110) / 3600:.1f}h\n")

    t0 = time.perf_counter()

    # One result queue shared by all workers
    result_queue: multiprocessing.Queue = multiprocessing.Queue()

    processes = []
    for w in range(N_WORKERS):
        p = multiprocessing.Process(
            target=worker_entry,
            args=(
                domain_name,
                DECISIONS_PER_WORKER,
                w,
                str(workers_dir),
                BASE_SEED + w,
                SOLVER_TIMEOUT_MS,
                MAX_DECISIONS_PER_WORKER,
                CHECKPOINT_EVERY,
                result_queue,
            ),
            daemon=False,    # non-daemon so they survive orchestrator sleep
            name=f"{domain_name}_w{w:02d}",
        )
        p.start()
        processes.append(p)

    print(f"  all {N_WORKERS} processes started. PIDs: {[p.pid for p in processes]}\n")

    # ── collect results as workers finish ─────────────────────────────────────
    worker_results = []
    finished = 0
    while finished < N_WORKERS:
        try:
            result = result_queue.get(timeout=60)   # check every 60s
            worker_results.append(result)
            finished += 1
            elapsed  = time.perf_counter() - t0
            done_decisions = sum(r["n_decisions"] for r in worker_results)
            total_expected = DECISIONS_PER_DOMAIN
            agg_rps = done_decisions / elapsed if elapsed > 0 else 0
            print(
                f"  worker {result['worker_id']:02d} done — "
