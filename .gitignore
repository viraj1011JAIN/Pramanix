# ─────────────────────────────────────────────────────────────────────────────
# Pramanix .gitignore — Python 3.11+ / Z3 / Poetry
# ─────────────────────────────────────────────────────────────────────────────

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
.eggs/
sdist/
wheels/

# Virtual environments
.venv/
venv/
ENV/
env/

# IDE / Editor
.idea/
.vscode/
*.swp
*.swo
*~
.project
.settings/
*.sublime-project
*.sublime-workspace

# mypy
.mypy_cache/
dmypy.json

# ruff
.ruff_cache/

# pytest
.pytest_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# Hypothesis
.hypothesis/

# Environment variables
.env
.env.*
!.env.example

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Z3 build artifacts
*.o
*.dylib

# Jupyter
.ipynb_checkpoints/

# Benchmarks output
benchmarks/results/
*.bench.json

# Docker
docker-compose.override.yml

# Secrets / credentials
*.pem
*.key
credentials.json
secrets.yaml
