# .env.test.example — copy to .env.test and fill in real credentials.
# .env.test is gitignored and loaded automatically by tests/conftest.py.
#
# Phase 1 hardening: No hardcoded API keys in test code.
# All external-service credentials must come from .env.test (local) or
# CI secret injection (CI/CD).  Leave a key blank to skip the tests that
# require it (they will be marked xfail/skip automatically).

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Google Gemini ─────────────────────────────────────────────────────────────
GOOGLE_API_KEY=

# ── Cohere ────────────────────────────────────────────────────────────────────
COHERE_API_KEY=

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=

# ── Splunk HEC ────────────────────────────────────────────────────────────────
SPLUNK_HEC_URL=
SPLUNK_HEC_TOKEN=

# ── Datadog ───────────────────────────────────────────────────────────────────
DD_API_KEY=
DD_SITE=datadoghq.com

# ── AWS (for AwsKmsKeyProvider and S3AuditSink tests) ─────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
PRAMANIX_TEST_SECRET_ARN=
PRAMANIX_TEST_S3_BUCKET=

# ── Redis (for RedisDistributedBackend and RedisExecutionTokenVerifier) ───────
REDIS_URL=redis://localhost:6379/0

# ── PostgreSQL (for PostgresExecutionTokenVerifier) ───────────────────────────
POSTGRES_DSN=postgresql://pramanix:pramanix@localhost:5432/pramanix_test
