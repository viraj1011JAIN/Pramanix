# Pramanix Environment Configuration
# Copy this file to .env and fill in your real values.
# NEVER commit .env to source control.

# ── LLM API Keys ──────────────────────────────────────────────────────────────
# Anthropic Claude (required for AnthropicTranslator)
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# OpenAI / Azure OpenAI (required for OpenAICompatTranslator)
OPENAI_API_KEY=sk-YOUR_KEY_HERE
# Optional: override base URL for Azure, vLLM, LMStudio, etc.
# OPENAI_BASE_URL=https://your-deployment.openai.azure.com/

# Google AI Studio (required for GeminiTranslator)
GOOGLE_API_KEY=AIza-YOUR_KEY_HERE

# Mistral AI (required for MistralTranslator)
MISTRAL_API_KEY=YOUR_MISTRAL_KEY_HERE

# Cohere (required for CohereTranslator)
COHERE_API_KEY=YOUR_COHERE_KEY_HERE

# ── Audit Sink Credentials ────────────────────────────────────────────────────
# Datadog (required for DatadogAuditSink)
DD_API_KEY=YOUR_DATADOG_API_KEY_HERE
DD_SITE=datadoghq.com

# Splunk HEC (required for SplunkHecAuditSink)
PRAMANIX_SPLUNK_HEC_URL=https://splunk.your-domain.com:8088/services/collector
PRAMANIX_SPLUNK_HEC_TOKEN=YOUR_SPLUNK_HEC_TOKEN_HERE

# ── Cryptographic Signing ─────────────────────────────────────────────────────
# Ed25519 private key PEM for PramanixSigner (production signing)
# Generate with: python -c "from pramanix.crypto import PramanixSigner; s = PramanixSigner.generate(); print(s.private_key_pem().decode())"
PRAMANIX_SIGNING_KEY_PEM=-----BEGIN PRIVATE KEY-----\nYOUR_ED25519_PRIVATE_KEY_PEM_HERE\n-----END PRIVATE KEY-----

# RS256 private key PEM for RS256Signer (JWT-compatible signing)
PRAMANIX_RS256_SIGNING_KEY_PEM=-----BEGIN PRIVATE KEY-----\nYOUR_RSA_PRIVATE_KEY_PEM_HERE\n-----END PRIVATE KEY-----

# ── Redis (Distributed Circuit Breaker + Intent Cache) ────────────────────────
PRAMANIX_REDIS_URL=redis://localhost:6379/0

# ── AWS S3 (S3AuditSink) ─────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_DEFAULT_REGION=us-east-1
PRAMANIX_S3_BUCKET=your-audit-bucket
PRAMANIX_S3_PREFIX=pramanix/audit/

# ── Kafka (KafkaAuditSink) ────────────────────────────────────────────────────
PRAMANIX_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
PRAMANIX_KAFKA_AUDIT_TOPIC=pramanix.audit

# ── Observability ─────────────────────────────────────────────────────────────
PRAMANIX_ENV=development
PRAMANIX_LOG_LEVEL=INFO
PRAMANIX_OTEL_ENABLED=false
PRAMANIX_METRICS_ENABLED=false

# OpenTelemetry endpoint (required when PRAMANIX_OTEL_ENABLED=true)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ── Guard Configuration ───────────────────────────────────────────────────────
PRAMANIX_SOLVER_TIMEOUT_MS=5000
PRAMANIX_MAX_WORKERS=4
PRAMANIX_SOLVER_RLIMIT=10000000
PRAMANIX_MAX_INPUT_BYTES=65536
PRAMANIX_INJECTION_THRESHOLD=0.5
