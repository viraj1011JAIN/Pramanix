# production.in — top-level production dependencies for pramanix[all]
#
# Regenerate the hashed lockfile with:
#   pip install pip-tools
#   pip-compile --generate-hashes --output-file=requirements/production.txt requirements/production.in
#
# Individual packages are listed here (not pramanix[all]) because pramanix is
# a local development package not published to PyPI, so pip-compile must
# resolve all deps from their upstream sources.
#
# Commit both this file and the generated production.txt to the repository.

